# ============================================
# Medical VQA System — Environment Variables
# ============================================
# Copy this to .env and modify as needed.
# All values have sensible defaults.

# ---- Model Paths ----
# Path to STLLaVA-Med model weights (local or HuggingFace model ID)
STLLAVA_MODEL_PATH=ZachSun/stllava-med-7b
STLLAVA_MODEL_BASE=liuhaotian/llava-v1.5-7b

# Path to Grounding DINO checkpoint
GROUNDING_DINO_CHECKPOINT=checkpoints/groundingdino_swint_ogc.pth
GROUNDING_DINO_CONFIG=GroundingDINO/groundingdino/config/GroundingDINO_SwinT_OGC.py

# Path to SAM2 checkpoint
SAM2_CHECKPOINT=checkpoints/sam2.1_hiera_large.pt
SAM2_CONFIG=configs/sam2.1/sam2.1_hiera_l.yaml

# ---- Inference Settings ----
# Options: auto, cuda, mps, cpu
DEVICE=auto
MAX_NEW_TOKENS=512
TEMPERATURE=0.2
LOAD_IN_8BIT=false
LOAD_IN_4BIT=false

# ---- Model Management ----
# Set to true to auto-download models on startup
AUTO_DOWNLOAD_MODELS=true
MODEL_CACHE_DIR=model_cache

# ---- API Settings ----
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["*"]
MAX_UPLOAD_SIZE_MB=50

# ---- Output Settings ----
OUTPUT_DIR=backend/outputs
LOG_LEVEL=INFO
LOG_FILE=
